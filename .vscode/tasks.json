{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Sync", 
        "type": "shell",
        "command": "git pull && git push gitlab master",
        "group": "none",
        "presentation": {
          "reveal": "always",
          "panel": "new"
        },
        "runOptions": {
          "runOn": "folderOpen"
        }
      }
      ,{
        "label": "Build TS",
        "type": "shell",
        "command": "npm run build",
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        },
        "problemMatcher": "$tsc"
      }
    ]
}